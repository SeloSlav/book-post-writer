{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "types": ["node"],
    "rootDir": ".",
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["pipeline/**/*.ts", "cli/**/*.ts", "server/**/*.ts"]
}
