{
  "name": "book-post-writer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,vite -c blue,green \"npm run editor-api\" \"vite\"",
    "dev:vite": "vite",
    "editor-api": "tsx server/editor-server.ts",
    "dev:editor": "npm run dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "ingest": "tsx cli/ingest.ts",
    "ingest:books": "tsx cli/ingest-books.ts",
    "ingest:voice": "tsx cli/ingest-voice.ts",
    "embed": "tsx cli/embed.ts",
    "draft": "tsx cli/draft.ts",
    "full": "tsx cli/full.ts",
    "pipeline:check": "tsc -p tsconfig.pipeline.json"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.4",
    "gray-matter": "^4.0.3",
    "lunr": "^2.3.9",
    "mammoth": "^1.12.0",
    "openai": "^6.34.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
